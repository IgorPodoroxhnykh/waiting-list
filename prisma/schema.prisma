generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ====================== Клиент ======================
model Client {
  id        String   @id @default(cuid())
  name      String
  phone     String?
  carNumber String?  @unique // госномер авто
  carBrand  String? // марка
  carModel  String? // модель
  carColor  String? // цвет
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  appointments Appointment[]
  liveQueue    LiveQueue[]
  washSessions WashSession[]
}

// ====================== Запись по времени ======================
model Appointment {
  id       String @id @default(cuid())
  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  startTime DateTime // запланированное время начала
  duration  Int               @default(30) // длительность в минутах
  status    AppointmentStatus @default(PENDING)

  services String? // услуги (текстом)
  price    Int? // сумма
  isPaid   Boolean @default(false)

  confirmedAt DateTime? // когда подтвердил прибытие
  arrivalTime DateTime? // фактическое прибытие
  boxId       String?
  box         Box?      @relation(fields: [boxId], references: [id])

  washSession WashSession? // связь с сессией мойки

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([startTime])
  @@index([status])
}

// ====================== Живая очередь ======================
model LiveQueue {
  id       String @id @default(cuid())
  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  arrivalTime DateTime        @default(now()) // время прибытия
  status      LiveQueueStatus @default(WAITING)

  services String? // услуги
  price    Int? // сумма
  isPaid   Boolean @default(false)

  position  Int? // позиция в очереди (вычисляется)
  invitedAt DateTime? // когда пригласили на мойку

  boxId String?
  box   Box?    @relation(fields: [boxId], references: [id])

  washSession WashSession? // связь с сессией мойки

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([arrivalTime])
  @@index([status])
}

// ====================== Сессия мойки ======================
model WashSession {
  id    String @id @default(cuid())
  boxId String
  box   Box    @relation(fields: [boxId], references: [id])

  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  appointmentId String?      @unique // если мойка по записи
  appointment   Appointment? @relation(fields: [appointmentId], references: [id])

  liveQueueId String?    @unique // если мойка из живой очереди
  liveQueue   LiveQueue? @relation(fields: [liveQueueId], references: [id])

  startTime DateTime
  endTime   DateTime? // фактическое окончание
  duration  Int? // фактическая длительность

  status   WashStatus @default(IN_PROGRESS)
  isWashed Boolean    @default(false) // помыт / готов
  isPaid   Boolean    @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([startTime])
  @@index([boxId, status])
}

// ====================== Бокс ======================
model Box {
  id       String  @id @default(cuid())
  number   Int     @unique // номер бокса
  isActive Boolean @default(true) // активен / на обслуживании

  appointments Appointment[]
  liveQueue    LiveQueue[]
  washSessions WashSession[]
}

// ====================== Настройки ======================
model Setting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       Json // универсальное значение
  description String?
  updatedAt   DateTime @updatedAt
}

// ====================== Пользователи (админы) ======================
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         UserRole @default(OPERATOR)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  events EventLog[]
}

// ====================== Журнал событий ======================
model EventLog {
  id          String   @id @default(cuid())
  timestamp   DateTime @default(now())
  type        String // APPOINTMENT_CREATED, CLIENT_ARRIVED, WASH_STARTED и т.д.
  description String
  data        Json? // дополнительные данные

  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  relatedId   String? // id связанной сущности
  relatedType String? // тип сущности (Appointment, LiveQueue, WashSession)

  @@index([timestamp])
  @@index([type])
}

// ====================== Enums ======================
enum AppointmentStatus {
  PENDING // ожидает подтверждения
  CONFIRMED // подтверждено
  CANCELLED // отменено
  COMPLETED // выполнено
  NO_SHOW // не явился
}

enum LiveQueueStatus {
  WAITING // в очереди
  INVITED // приглашён
  IN_PROGRESS // в работе
  COMPLETED // помыт
  LEFT // ушёл
}

enum WashStatus {
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum UserRole {
  ADMIN
  OPERATOR
}
