generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ====================== Клиент ======================
model Client {
  id        String   @id @default(cuid())
  name      String
  phone     String?
  carNumber String?  @unique
  carBrand  String?
  carModel  String?
  carColor  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  queueEntries  QueueEntry[]
  washSessions  WashSession[]
  notifications Notification[]
}

// ====================== Единая очередь ======================
model QueueEntry {
  id       String @id @default(cuid())
  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  // Источник записи
  source QueueEntrySource // LIVE, SCHEDULED, ADMIN

  // Статус
  status   QueueEntryStatus @default(CREATED)
  priority Int              @default(0) // для VIP и срочных

  // Время
  requestedStartAt DateTime? // что хотел клиент (null = "как можно скорее")
  plannedStartAt   DateTime // расчётное/подтверждённое время старта
  plannedEndAt     DateTime // plannedStartAt + duration

  // Длительность
  estimatedDurationMin Int  @default(30)
  actualDurationMin    Int? // фактическая (если отличается)

  // Дедлайны и факты
  checkinDeadlineAt DateTime? // plannedStartAt + grace period
  checkedInAt       DateTime? // когда клиент прибыл
  actualStartAt     DateTime? // реальное начало мойки
  actualEndAt       DateTime? // реальное окончание

  // Услуги и оплата
  services String?
  price    Int?
  isPaid   Boolean @default(false)

  // Бокс (назначается при старте мойки)
  boxId String?
  box   Box?    @relation(fields: [boxId], references: [id])

  // Optimistic lock
  version Int @default(1)

  // Связь с сессией мойки
  washSession WashSession?

  // Примечания
  notes String? // комментарии админа

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, plannedStartAt])
  @@index([source, status, createdAt])
  @@index([clientId, status])
}

// ====================== Сессия мойки ======================
model WashSession {
  id    String @id @default(cuid())
  boxId String
  box   Box    @relation(fields: [boxId], references: [id])

  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  queueEntryId String?     @unique
  queueEntry   QueueEntry? @relation(fields: [queueEntryId], references: [id])

  startTime DateTime
  endTime   DateTime?
  duration  Int?

  status   WashStatus @default(IN_PROGRESS)
  isWashed Boolean    @default(false)
  isPaid   Boolean    @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([startTime])
  @@index([boxId, status])
}

// ====================== Бокс ======================
model Box {
  id       String  @id @default(cuid())
  number   Int     @unique
  isActive Boolean @default(true)

  queueEntries QueueEntry[]
  washSessions WashSession[]
}

// ====================== Версионные настройки ======================
model SystemConfig {
  id String @id @default(cuid())

  effectiveFrom DateTime // когда вступает в силу

  // Основные параметры
  activeBoxesCount   Int // количество активных боксов
  defaultDurationMin Int // стандартная длительность мойки
  slotStepMin        Int @default(5) // шаг слотов для записи

  // Правила очереди
  liveQueueMaxWaitMin Int @default(120) // макс. ожидание в живой очереди
  noShowGraceMin      Int @default(15) // время на опоздание
  reminderBeforeMin   Int @default(30) // за сколько напоминать

  // Рабочее время
  workStartHour Int    @default(8) // начало работы (часы)
  workEndHour   Int    @default(22) // конец работы (часы)
  workDays      String @default("1,2,3,4,5,6,7") // пн-вс

  createdById String?
  createdBy   User?   @relation("ConfigCreatedBy", fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])
  userId    String?

  @@index([effectiveFrom])
}

// ====================== Пользователи (админы) ======================
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  role         UserRole @default(OPERATOR)
  isActive     Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  events         EventLog[]
  createdConfigs SystemConfig[] @relation("ConfigCreatedBy")
  systemConfigs  SystemConfig[]
}

// ====================== Уведомления ======================
model Notification {
  id       String @id @default(cuid())
  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  type    NotificationType
  channel NotificationChannel @default(PUSH)

  title   String
  message String
  data    Json?

  scheduledAt DateTime
  sentAt      DateTime?
  status      NotificationStatus @default(PENDING)

  createdAt DateTime @default(now())

  @@index([clientId, status])
  @@index([scheduledAt])
}

// ====================== Журнал событий ======================
model EventLog {
  id          String   @id @default(cuid())
  timestamp   DateTime @default(now())
  type        String
  description String
  data        Json?

  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  relatedId   String?
  relatedType String? // QueueEntry, WashSession, Client, etc.

  @@index([timestamp])
  @@index([type])
  @@index([relatedId, relatedType])
}

// ====================== Enums ======================
enum QueueEntrySource {
  LIVE // живая очередь - "как можно скорее"
  SCHEDULED // предварительная запись на время
  ADMIN // создана администратором
}

enum QueueEntryStatus {
  CREATED // создана, ожидает
  CONFIRMED // подтверждена (клиент получил уведомление)
  CHECKED_IN // клиент прибыл
  IN_SERVICE // мойка в процессе
  COMPLETED // завершена
  CANCELLED // отменена
  NO_SHOW // клиент не явился
  EXPIRED // истёк срок ожидания
}

enum WashStatus {
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum UserRole {
  ADMIN
  OPERATOR
}

enum NotificationType {
  REMINDER // напоминание о записи
  QUEUE_UPDATE // изменение позиции в очереди
  READY // бокс готов, можно заезжать
  CANCELLED // запись отменена
  DELAY // задержка
}

enum NotificationChannel {
  PUSH
  SMS
  EMAIL
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
}
